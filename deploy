#!/bin/bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}🚀 BULA2026 → IONOS Deploy${NC}\n"

# Check builds
if [ ! -d "frontend/dist-admin" ] || [ ! -d "frontend/dist-registration" ]; then
    echo -e "${RED}✗ Apps nicht gebaut!${NC}"
    echo "Starten: npm run build:admin && npm run build:registration"
    exit 1
fi

# Ask what to deploy
echo -e "${BLUE}Was deployen?${NC}"
echo "1) Admin + Backend (complete)"
echo "2) Registration only"
echo "3) Beides (both complete)"
read -p "Wahl (1-3): " CHOICE

echo -e "\n${YELLOW}Uploade...${NC}\n"

case $CHOICE in
    1|3)
        echo -e "${BLUE}📤 Backend + Admin (komplett)${NC}"

        # Backend Files - PUBLIC (main entry point)
        echo -e "${YELLOW}  → Public files...${NC}"
        scp backend-php/public/index.php ionos:/www/htdocs/w01e9b9c/lagerbank.info/

        # Backend Files - SRC (API handlers)
        echo -e "${YELLOW}  → API files...${NC}"
        scp -r backend-php/src/* ionos:/www/htdocs/w01e9b9c/lagerbank.info/src/ 2>/dev/null || mkdir -p /tmp/backend-src
        scp -r backend-php/src/ ionos:/www/htdocs/w01e9b9c/lagerbank.info/

        # Backend Files - CONFIG
        echo -e "${YELLOW}  → Config files...${NC}"
        scp -r backend-php/config/* ionos:/www/htdocs/w01e9b9c/lagerbank.info/config/

        # Database Schema
        echo -e "${YELLOW}  → Database schema...${NC}"
        scp schema.sql ionos:/www/htdocs/w01e9b9c/lagerbank.info/
        scp reset-db.sql ionos:/www/htdocs/w01e9b9c/lagerbank.info/

        # Admin Frontend
        echo -e "${YELLOW}  → Admin frontend...${NC}"
        scp -r frontend/dist-admin/assets/* ionos:/www/htdocs/w01e9b9c/lagerbank.info/assets/
        scp frontend/dist-admin/index.html ionos:/www/htdocs/w01e9b9c/lagerbank.info/

        # .htaccess für URL Rewriting
        echo -e "${YELLOW}  → .htaccess...${NC}"
        scp .htaccess ionos:/www/htdocs/w01e9b9c/lagerbank.info/

        echo -e "${GREEN}✓ Admin + Backend OK${NC}"
        ;;
esac

case $CHOICE in
    2|3)
        echo -e "${BLUE}📤 Registration (komplett)${NC}"

        # Registration Frontend
        echo -e "${YELLOW}  → Registration frontend...${NC}"
        scp -r frontend/dist-registration/assets/* ionos:/www/htdocs/w01e9b9c/anmeldung.lagerbank.info/assets/
        scp frontend/dist-registration/registration.html ionos:/www/htdocs/w01e9b9c/anmeldung.lagerbank.info/index.html

        # .htaccess für URL Rewriting
        echo -e "${YELLOW}  → .htaccess...${NC}"
        scp .htaccess ionos:/www/htdocs/w01e9b9c/anmeldung.lagerbank.info/

        echo -e "${GREEN}✓ Registration OK${NC}"
        ;;
esac

echo -e "\n${GREEN}✓ FERTIG!${NC}"
echo -e "\nDeployment erfolgreich hochgeladen."
echo -e "Änderungen sind live auf:"
echo -e "  - Admin: https://lagerbank.info"
echo -e "  - Registration: https://anmeldung.lagerbank.info"
echo -e "\n${YELLOW}Nächste Schritte:${NC}"
echo -e "1. Melde dich in phpMyAdmin an"
echo -e "2. Führe reset-db.sql aus (SQL-Tab)"
echo -e "3. Importiere schema.sql (Import-Tab)"
echo -e "4. Login mit: admin@lagerbank.info / admin123"

